# App
APP_NAME=WhatsApp SaaS Platform
SECRET_KEY=your-super-secret-key-change-this
ENVIRONMENT=development
DEBUG=True

# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=whatsapp_saas
DATABASE_URL=postgresql://postgres:postgres@db:5432/whatsapp_saas

# Redis + Celery
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Meta WhatsApp Cloud API
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
META_API_VERSION=v19.0
META_BASE_URL=https://graph.facebook.com
WEBHOOK_VERIFY_TOKEN=your_webhook_verify_token

# Razorpay
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_SECRET=your_razorpay_secret

# Encryption (for storing WA access tokens)
ENCRYPTION_KEY=your-32-char-encryption-key-here

# Email (for alerts)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=your_app_password

# Platform
PLATFORM_DOMAIN=yourplatform.com
SUPERADMIN_EMAIL=admin@yourplatform.com
SUPERADMIN_PASSWORD=changeme123
